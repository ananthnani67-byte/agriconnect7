5. Open App.js file in the /src folder, Replace the following code.
import React, { useState, useEffect } from 'react';
import { getCurrentWeather, getHistoricalWeather } from './services/weatherService';
import WeatherDisplay from './components/WeatherDisplay';
import WeatherChart from './components/WeatherChart';
function App() {
 const [currentWeather, setCurrentWeather] = useState(null);
 const [historicalData, setHistoricalData] = useState([]);
 useEffect(() => {
 const fetchWeather = async () => {
 const city = "Hyderabad"; // you can change or make it dynamic
 const current = await getCurrentWeather(city);
 setCurrentWeather(current);
 // Fetch last 5 hours historical data
 const { coord } = current;
 const now = Math.floor(Date.now() / 1000);
 let history = [];
 for (let i = 1; i <= 5; i++) {
 const past = await getHistoricalWeather(coord.lat, coord.lon, now - i * 3600);
 history.push({ dt: past.current.dt, temp: past.current.temp });
 }
 setHistoricalData(history);
 };
 fetchWeather();
 }, []);
 return (
 <div>
 <h1>Weather App</h1>
 {currentWeather && <WeatherDisplay weather={currentWeather} />}
 {historicalData.length > 0 && <WeatherChart data={historicalData} />}
 </div>
 );
}
export default App;
