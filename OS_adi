#include <stdio.h>
#include <stdlib.h>

struct list {
    int seg, base, limit;
    struct list *next;
} *p = NULL;

// Insert node
void insert(int base, int limit, int seg) {
    struct list *temp, *q = p;

    temp = (struct list*)malloc(sizeof(struct list));
    temp->base = base;
    temp->limit = limit;
    temp->seg = seg;
    temp->next = NULL;

    if (p == NULL) {
        p = temp;
    } else {
        while (q->next != NULL)
            q = q->next;
        q->next = temp;
    }
}

// Find limit
int find(int seg) {
    struct list *q = p;
    while (q != NULL && q->seg != seg)
        q = q->next;

    if (q == NULL)
        return -1;   

    return q->limit;
}

// Find base
int search(int seg) {
    struct list *q = p;
    while (q != NULL && q->seg != seg)
        q = q->next;

    if (q == NULL)
        return -1;   

    return q->base;
}

int main() {
    int seg, offset, limit, base, physical;

    printf("Enter segment table\n");
    printf("Enter -1 as segment value for termination\n");

    do {
        printf("Enter segment number: ");
        scanf("%d", &seg);

        if (seg != -1) {
            printf("Enter base value: ");
            scanf("%d", &base);
            printf("Enter limit value: ");
            scanf("%d", &limit);
            insert(base, limit, seg);
        }
    } while (seg != -1);

    printf("Enter offset: ");
    scanf("%d", &offset);

    printf("Enter segmentation number: ");
    scanf("%d", &seg);

    limit = find(seg);
    base = search(seg);

    if (limit == -1 || base == -1) {
        printf("Error: Segment not found\n");  
    } else if (offset < limit) {
        physical = base + offset;
        printf("Address in physical memory: %d\n", physical);
    } else {
        printf("Error: Offset exceeds limit\n");
    }

    return 0;
}